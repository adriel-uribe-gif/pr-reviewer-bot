# GitHub Personal Access Token
# For IBM GitHub Enterprise: https://github.ibm.com/settings/tokens
# For public GitHub: https://github.com/settings/tokens
# Required scopes: repo (for private repos) or public_repo (for public repos)
GITHUB_TOKEN=your_github_token_here

# GitHub API base URL
# IBM GitHub Enterprise:
GITHUB_API_URL=https://github.ibm.com/api/v3
# Public GitHub (default, uncomment to switch):
# GITHUB_API_URL=https://api.github.com
